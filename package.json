{
  "name": "accumulatingpoints",
  "productName": "צבירת נקודות",
  "description": "צבירת נקודות דיגיטלית",
  "version": "2.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "watch": "nodemon --exec electron .",
    "postinstall": "electron-builder install-app-deps",
    "pack:win": "electron-builder --win --x64 -c.npmRebuild=false",
    "reset": "git reset --hard",
    "build": "electron-builder --help"
  },
  "repository": "https://github.com/EfratVardi/ElectronBarcode.git",
  "keywords": [
    "Electron",
    "barcode"
  ],
  "author": "Efrat Malka",
  "license": "CC0-1.0",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^22.8.0",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^2.0.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.2",
    "jquery": "^3.6.3",
    "sqlite3": "5.1.6"
  },
  "build": {
    "npmRebuild": false,
    "extraResources": [
      "./extraResources/**"
    ]
  }
}
